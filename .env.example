# ── Client (Expo) — build-time, PUBLIC values only ──────────────────────────
# These are bundled into the app. Use ONLY the Supabase URL + anon key here.
# Never put the service_role key or any ElevenLabs/Anthropic key in this file.
#
# Copy this file to `.env` and fill in your project's values.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-SUPABASE-ANON-KEY

# ── Server (Supabase Edge Function secrets) — DO NOT put these in .env ───────
# Set these with the Supabase CLI instead (they never reach the client):
#
#   supabase secrets set \
#     ELEVENLABS_API_KEY=... \
#     ELEVENLABS_AGENT_ID=... \
#     ELEVENLABS_WEBHOOK_SECRET=...
#
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are injected automatically.
